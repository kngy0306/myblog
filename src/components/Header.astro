---
import { Image } from "astro:assets";
import logoImage from "@/images/logo.svg";
---

<header>
  <nav>
    <div class="max-w-screen border-b-1 flex flex-wrap items-center justify-between mx-auto py-4 max-[450px]:flex-col">
      <div class="">
        <a
          href="/"
          class="flex items-center space-x-2 rtl:space-x-reverse hover:text-muted-foreground transition-all duration-200"
        >
          <Image src={logoImage} width={32} height={32} alt="logo画像" class="rounded-md" />
          <span class="self-center text-2xl font-bold whitespace-nowrap font-sans">こなぶろぐ</span>
        </a>
      </div>

      <div class="w-auto max-[450px]:pt-5 flex items-center gap-1" id="navbar-default">
        <ul class="flex rounded-lg flex-row gap-3">
          <li>
            <a
              href="/"
              class="block select-none space-y-1 rounded-md p-3 leading-none no-underline outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground"
              aria-current="page">Home</a
            >
          </li>
          <li>
            <a
              href="/about"
              class="block select-none space-y-1 rounded-md p-3 leading-none no-underline outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground"
              >About</a
            >
          </li>
        </ul>
        <button
          id="theme-toggle"
          type="button"
          aria-label="テーマを切り替える"
          class="rounded-md p-3 leading-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg id="theme-icon-light" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg id="theme-icon-dark" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  function updateThemeIcons() {
    const isDark = document.documentElement.classList.contains("dark");
    document.getElementById("theme-icon-light").classList.toggle("hidden", !isDark);
    document.getElementById("theme-icon-dark").classList.toggle("hidden", isDark);
  }

  updateThemeIcons();

  document.getElementById("theme-toggle").addEventListener("click", function () {
    const isDark = document.documentElement.classList.contains("dark");
    if (isDark) {
      document.documentElement.classList.remove("dark");
      document.documentElement.classList.add("light");
      localStorage.setItem("theme", "light");
    } else {
      document.documentElement.classList.remove("light");
      document.documentElement.classList.add("dark");
      localStorage.setItem("theme", "dark");
    }
    updateThemeIcons();
  });
</script>
